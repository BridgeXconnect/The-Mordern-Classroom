# ─────────────────────────────────────────────
# Modern Classroom — Environment Variables
# Copy this file to .env.local and fill values
# ─────────────────────────────────────────────

# Clerk Authentication (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Database — Neon PostgreSQL (https://neon.tech)
DATABASE_URL=

# OpenRouter API (https://openrouter.ai)
OPENROUTER_API_KEY=

# Hugging Face — free image generation (https://huggingface.co)
HF_TOKEN=

# YouTube Data API v3 (https://console.cloud.google.com)
YOUTUBE_API_KEY=

# Google Cloud Text-to-Speech (https://console.cloud.google.com)
# Option A: JSON key file path (local dev)
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: Inline JSON credentials (Vercel / production)
GOOGLE_TTS_CREDENTIALS=

# Cloudflare R2 Object Storage (https://dash.cloudflare.com)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

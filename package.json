{
  "name": "modern-classroom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--no-experimental-webstorage' next dev",
    "build": "prisma db push --skip-generate && NODE_OPTIONS='--no-experimental-webstorage' next build",
    "start": "NODE_OPTIONS='--no-experimental-webstorage' next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^6.0.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/text-to-speech": "^5.3.0",
    "@huggingface/inference": "^2.8.0",
    "@openrouter/sdk": "^0.0.1",
    "@prisma/client": "^5.16.0",
    "@react-pdf/renderer": "^3.4.4",
    "@remotion/renderer": "^4.0.0",
    "@sparticuz/chromium": "^123.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.400.0",
    "next": "15.5.18",
    "openai": "^4.52.0",
    "pptxgenjs": "^3.12.0",
    "puppeteer-core": "^22.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "shadcn": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.3.3",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "prisma": "^5.16.0",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
